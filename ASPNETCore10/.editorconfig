root = true

[*]
indent_style = space
indent_size = 4
max_line_length = 100
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cshtml, html, css, json, js, ts, csproj, sln, slnx, xml, props, config, targets}]
indent_size = 2

[*.{cs}]
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false